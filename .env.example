# ==============================================================
# MGSPlus — Secrets & Environment Flags
# Copy to .env and fill in real values.
# DO NOT commit the real .env file.
#
# Non-secret config (ports, hosts, URLs) lives in configs/*.yml
# ==============================================================

# ── Docker / App environment ───────────────────────────────────
COMPOSE_PROJECT_NAME=mgsplus
ASPNETCORE_ENVIRONMENT=Development

# ── SQL Server ────────────────────────────────────────────────
SA_PASSWORD=YourStrong!Passw0rd
MSSQL_SA_PASSWORD=YourStrong!Passw0rd
ACCEPT_EULA=Y

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here!!

# ── Qdrant ────────────────────────────────────────────────────
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_READ_ONLY_API_KEY=your-readonly-key-here
QDRANT__SERVICE__API_KEY=your-qdrant-api-key
QDRANT__SERVICE__READ_ONLY_API_KEY=your-readonly-key-here

# ── Neo4j ─────────────────────────────────────────────────────
NEO4J_PASSWORD=your-neo4j-password
NEO4J_AUTH=neo4j/your-neo4j-password

# ── LLM ───────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Ollama cloud API key (leave as "ollama" for local Ollama, set real key for cloud)
OLLAMA_API_KEY=ollama

# ── SMTP (optional — leave SMTP_HOST blank to disable email) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mgsplus.com

# ── Admin account (created at first startup if not exists) ────
ADMIN_EMAIL=admin@mgsplus.vn
ADMIN_PASSWORD=Admin@123456

# ── Kaggle (data pipeline only) ───────────────────────────────
KAGGLE_USERNAME=
KAGGLE_KEY=
