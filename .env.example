# ============================================================
# MGSPlus — Shared Environment Variables
# Copy to .env and fill in real values.
# DO NOT commit the real .env file.
# ============================================================

# ── Application ──────────────────────────────────────────────
APP_ENV=development
COMPOSE_PROJECT_NAME=mgsplus

# ── SQL Server ────────────────────────────────────────────────
SQLSERVER_HOST=sqlserver
SQLSERVER_PORT=1433
SQL_ADMIN_USER=sa
SA_PASSWORD=YourStrong!Passw0rd
SQLSERVER_DB=mgsplus_db
ACCEPT_EULA=Y

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-here!!
JWT_ISSUER=MGSPlus
JWT_AUDIENCE=MGSPlusApp
JWT_EXPIRES_MINUTES=60

# ── Qdrant (Vector Database) ──────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_READ_ONLY_API_KEY=your-readonly-key-here

# ── Neo4j ────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# ── LLM / Agents ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# ── Backend (ASP.NET Core) ────────────────────────────────────
BACKEND_PORT=5000
ASPNETCORE_ENVIRONMENT=Development

# ── Frontend (Vue.js) ─────────────────────────────────────────
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:5000/api
VITE_WS_URL=ws://localhost:5000

# ── Agent service ports ───────────────────────────────────────
SUPERVISOR_PORT=8010
DOCUMENTS_PORT=8011
WORKFLOW_PORT=8012

# ── MCP server URLs ───────────────────────────────────────────
MCP_ZALO_URL=http://localhost:3001
MCP_MESSENGER_URL=http://localhost:3002
MCP_WIKI_URL=http://localhost:3003

# ── Memory / Agent settings ───────────────────────────────────
SHORT_TERM_TTL_SECONDS=3600
LONG_TERM_SUMMARY_THRESHOLD=20

# ── Jenkins ───────────────────────────────────────────────────
JENKINS_PORT=8080
JENKINS_AGENT_PORT=50000

# ── Locust (Load testing) ─────────────────────────────────────
LOCUST_HOST=http://localhost:5000
LOCUST_WEB_PORT=8089

# ── Agent service ports ───────────────────────────────────────
# SUPERVISOR_PORT=8010
# DOCUMENTS_PORT=8011
# WORKFLOW_PORT=8012

# ── MCP server URLs (optional) ────────────────────────────────
# MCP_ZALO_URL=http://localhost:3001
# MCP_MESSENGER_URL=http://localhost:3002
# MCP_WIKI_URL=http://localhost:3003

# ── Memory settings ───────────────────────────────────────────
# SHORT_TERM_TTL_SECONDS=3600
# LONG_TERM_SUMMARY_THRESHOLD=20
