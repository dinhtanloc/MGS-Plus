# Infrastructure Configuration
# Copy to .env.local and customize with your values

# ========================================
# Qdrant (Vector Database)
# ========================================
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
# API Keys (optional, for authentication)
QDRANT_API_KEY=your-api-key-here
QDRANT_READ_ONLY_API_KEY=your-readonly-key-here

# ========================================
# PostgreSQL Configuration
# ========================================
POSTGRES_USER=admin
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=mgsplus_db
POSTGRES_PORT=5432

# ========================================
# SQL Server Configuration
# ========================================
SA_PASSWORD=YourSuperStrong@Password123
SQL_ADMIN_USER=sa
ACCEPT_EULA=Y
SQLSERVER_PORT=1433

# ========================================
# Docker Compose Settings
# ========================================
COMPOSE_PROJECT_NAME=mgsplus

# ========================================
# Infrastructure Deployment (Future)
# ========================================
# Terraform variables will go here
# AWS_REGION=us-east-1
# AWS_PROFILE=default

# Kubernetes settings will go here
# K8S_NAMESPACE=default
# K8S_REGISTRY=your-registry.azurecr.io
